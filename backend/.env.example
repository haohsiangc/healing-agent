# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Token (required only for real SDXL generation)
HF_TOKEN=hf_...

# JWT Secret Key — change this to a random string in production
SECRET_KEY=supersecretchangeme

# Image Generation: set to False only if you have a CUDA GPU + LoRA weights
MOCK_IMAGE_GENERATION=true

# Path to LoRA weights (only needed if MOCK_IMAGE_GENERATION=false)
LORA_PATH=./tbh368-sdxl.safetensors

# Path to meditation audio
MEDITATION_AUDIO_PATH=./static/meditation_v2.m4a

# Database (SQLite by default)
DATABASE_URL=sqlite:///./healing_bot.db

# Anthropic model
ANTHROPIC_MODEL=claude-haiku-4-5

# Debug
DEBUG=false
